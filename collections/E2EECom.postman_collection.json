          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "\r",
              "const req = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "//response validations\r",
              "\r",
              "pm.test(\"Validate token field\", function () {\r",
