  "item": [
    {
      "name": "Login success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"token\",res.token);\r",
              "pm.environment.set(\"userId\",res.userId);\r",
              "\r",
              "//Status code\r",
              "pm.test(\"Validate status code\",function(){\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Success message\r",
              "pm.test(\"Validate success message\", function(){\r",
              "\r",
              "    pm.expect(res.message).to.be.eql(\"Login Successfully\");\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"userEmail\": \"{{username}}\",\r\n    \"userPassword\": \"{{password}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{ecom_base_url}}/login",
          "host": [
            "{{ecom_base_url}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "contract success",
      "event": [
