              "    pm.expect(res).to.have.property(\"token\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate userId field\", function () {\r",
              "\r",
              "    pm.expect(res).to.have.property(\"userId\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate message field\", function () {\r",
              "\r",
              "    pm.expect(res).to.have.property(\"message\");\r",
              "});\r",
              "\r",
              "//request body validations\r",
              "pm.test(\"Validate userEmail field\", function () {\r",
              "\r",
              "    pm.expect(req).to.have.property(\"userEmail\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate userPassword field\", function () {\r",
              "\r",
              "    pm.expect(req).to.have.property(\"userPassword\");\r",
              "});\r",
              "\r",
              "\r",
              ""
